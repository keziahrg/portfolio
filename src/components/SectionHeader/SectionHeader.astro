---
import styles from './SectionHeader.module.css'

export interface Props {
    id?: string
    preheading?: string
    heading: string
}

const { id, preheading, heading } = Astro.props
---

<h2 id={id} class={styles['section-header']}>
    {
        preheading && (
            <strong class={styles['section-header__preheading']}>
                {preheading}
            </strong>
        )
    }
    <span class={styles['section-header__heading']}>{heading}</span>
</h2>
